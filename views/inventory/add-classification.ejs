 <% if (title) { %>
<h1><%= title %></h1>
<% } else { res.redirect('/') } %>

<%- messages() %>

<% if (errors) { %>
    <ul class="notice">
        <% errors.array().forEach(error => { %>
            <li><%= error.msg %></li>
            <% }) %>
        </ul>
    <% } %>

<form method="POST" action="/inv/add-classification" id="add-classification-form">
    <label for="classification_name">Classification Name:</label>
    <div>(Name must be Alphabetic Characters Only)</div>
    <input type="text" class="form-input" id="classification_name" name="classification_name" pattern="^[a-zA-Z]+$" title="Name must be Alphabetic Characters Only" required>
    <button type="submit">Add Classification</button>
</form>

