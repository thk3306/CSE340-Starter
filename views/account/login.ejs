 <% if (title) { %>
<h1><%= title %></h1>
<% } else { res.redirect('/') } %>

<%- messages() %>

<% if (errors) { %>
    <ul class="notice">
        <% errors.array().forEach(error => { %>
            <li><%= error.msg %></li>
            <% }) %>
        </ul>
    <% } %>

<form method="POST" action="/account/login" id="loginform">
    <label for="client-email" class="form-label">Email:</label>
    <input type="email" class="form-input" id="client-email" name="account_email" required value="<%= locals.account_email %>">
    <label for="client-password" class="form-label">Password:</label>
    <div>The password must be:
<ul>
    <li>12 characters in length, minimum</li>
    <li>contain at least 1 capital letter</li>
    <li>contain at least 1 number</li>
    <li>contain at least 1 special character</li>
</ul>
</div>
    <input type="password" class="form-input" id="client-password" name="account_password" required pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$">
    <button type="submit" class="form-buttom" id="login-button">Login</button>
    <p>No Account? <a href="/account/registration">Sign-up</a></p>
</form>